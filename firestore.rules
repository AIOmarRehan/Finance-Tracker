rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwnerByResource() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    function isOwnerByRequest() {
      return isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if true; // Needed for forgot-password email lookup (unauthenticated)
      allow create, update: if isSignedIn() && userId == request.auth.uid;
      allow delete: if isSignedIn() && userId == request.auth.uid;
    }

    match /transactions/{transactionId} {
      allow create: if isOwnerByRequest();
      allow read, update, delete: if isOwnerByResource();
    }

    match /categories/{categoryId} {
      allow create: if isOwnerByRequest();
      allow read, update, delete: if isOwnerByResource();
    }

    match /goals/{goalId} {
      allow create: if isOwnerByRequest();
      allow read, update, delete: if isOwnerByResource();
    }

    match /contactMessages/{messageId} {
      allow create: if true; // Allow anyone to create contact messages
      allow read, update, delete: if false; // Only admins (through Firebase Console)
    }
  }
}
